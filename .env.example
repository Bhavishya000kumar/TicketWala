# CineVerse Client Environment Variables Template
# Copy this file to '.env' and fill in active keys for development and production.

# Backend Express API URL
VITE_API_BASE_URL=http://localhost:5000/api

# Razorpay Checkout API Key
VITE_RAZORPAY_KEY=rzp_test_examplekey12345

# Cloudinary Cloud Name for Movie Poster uploads
VITE_CLOUDINARY_CLOUD_NAME=cineverse-cloud-uploads

# Firebase Client SDK Configuration
VITE_FIREBASE_API_KEY=AIzaSyA1234567890abcdefghijklmnopqrstuvwxyz
VITE_FIREBASE_AUTH_DOMAIN=cineverse-prod.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=cineverse-prod
VITE_FIREBASE_STORAGE_BUCKET=cineverse-prod.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
